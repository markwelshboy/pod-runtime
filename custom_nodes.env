#!/usr/bin/env bash
# Custom-node manifest selection.
# The default set is always installed; add optional comma/space-separated sets.
export CUSTOM_NODES_MANIFEST_URL="${CUSTOM_NODES_MANIFEST_URL_OVERRIDE:-https://raw.githubusercontent.com/markwelshboy/pod-runtime/main/default_custom_nodes_manifest.json}"
export CUSTOM_NODE_SETS="${CUSTOM_NODE_SETS:-}"

# Use the pack-aware resolver by default. An explicit override must use the
# dedicated *_OVERRIDE variable so re-sourcing helpers cannot retain an old
# resolver path from an earlier shell session.
export CUSTOM_NODES_WORKFLOW_TOOL="${CUSTOM_NODES_WORKFLOW_TOOL_OVERRIDE:-${POD_RUNTIME_DIR:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)}/bin/custom_nodes_from_workflow_v3.py}"
