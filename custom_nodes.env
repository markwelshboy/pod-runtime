#!/usr/bin/env bash
# Custom-node manifest selection.
# The default set is always installed; add optional comma/space-separated sets.
export CUSTOM_NODES_MANIFEST_URL="${CUSTOM_NODES_MANIFEST_URL_OVERRIDE:-https://raw.githubusercontent.com/markwelshboy/pod-runtime/main/default_custom_nodes_manifest.json}"
export CUSTOM_NODE_SETS="${CUSTOM_NODE_SETS:-}"
